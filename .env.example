# Portfolio Backend Configuration
# Copy this file to .env and fill in your values

# Server port (default: 3000)
PORT=3000

# Email Configuration (Gmail)
# To use Gmail, you need an App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords and generate one for "Mail"
EMAIL_USER=ishwaribelhekar11@gmail.com
EMAIL_PASS="your pass"

# Where to receive contact form messages
EMAIL_TO=ishwaribelhekar11@gmail.com
RESEND_API_KEY= your API
